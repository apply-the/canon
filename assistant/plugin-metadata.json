  "license": "MIT",
  "keywords": [
    "canon",
    "governance",
    "packets",
    "evidence",
    "approvals",
    "provenance",
    "ai-assisted-engineering"
  ],
  "positioning": [
    "Governed packet runtime for AI-assisted engineering work",
    "Structured packets, evidence, approvals, and provenance",
