{
  "name": "canon",
  "displayName": "Canon Assistant Support",
  "version": "0.52.0",
  "description": "Governed packet runtime for AI-assisted engineering work",
  "author": {
    "name": "Apply The",
    "url": "https://github.com/apply-the"
  },
  "homepage": "https://github.com/apply-the/canon",
